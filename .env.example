# Скопируй в .env и при необходимости измени

# --- Локальная разработка на ноуте (npm run dev) ---
VITE_BASE_PATH=/
VITE_API_BASE_URL=/api

# --- Для npm run dev:lan / Tauri (IP этого ноутбука в Wi‑Fi) ---
# VITE_API_BASE_URL=http://192.168.0.34:8080/api

# --- Tauri (раскомментируй в .env.tauri, не здесь) ---
# VITE_GUEST_MODE=true

# --- GitHub Pages (уже в .env.pages) ---
# VITE_BASE_PATH=/interplanetary-flights-frontend/
